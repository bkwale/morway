generator client {
  provider        = "prisma-client-js"
  output          = "../src/generated/prisma"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider     = "sqlite"
  url          = env("DATABASE_URL")
  relationMode = "prisma"
}

model Firm {
  id           String    @id @default(uuid())
  name         String
  email        String    @unique
  plan         String    @default("STARTER")
  trialEndsAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  users        User[]
  clients      Client[]
  rules        Rule[]

  @@map("firms")
}

model User {
  id               String            @id @default(uuid())
  firmId           String
  email            String            @unique
  emailVerified    DateTime?
  name             String
  role             String            @default("ACCOUNTANT")
  image            String?
  createdAt        DateTime          @default(now())
  firm             Firm              @relation(fields: [firmId], references: [id], onDelete: Cascade)
  exceptionReviews ExceptionReview[]
  accounts         Account[]
  sessions         Session[]

  @@map("users")
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Client {
  id               String     @id @default(uuid())
  firmId           String
  name             String
  vatNumber        String?
  peppolId         String?    @unique
  accountingSystem String     @default("NONE")
  xeroTenantId     String?    @unique
  xeroConnected    Boolean    @default(false)
  exactDivision    String?
  exactConnected   Boolean    @default(false)
  datevClientNo    String?
  datevConsultNo   String?
  active           Boolean    @default(true)
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  firm             Firm       @relation(fields: [firmId], references: [id], onDelete: Cascade)
  invoices         Invoice[]
  rules            Rule[]
  suppliers        Supplier[]

  @@map("clients")
}

model Supplier {
  id             String    @id @default(uuid())
  clientId       String
  name           String
  vatNumber      String?
  xeroContactId  String?
  defaultAccount String?
  client         Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  invoices       Invoice[]

  @@unique([clientId, vatNumber])
  @@map("suppliers")
}

model Invoice {
  id              String     @id @default(uuid())
  clientId        String
  supplierId      String?
  invoiceNumber   String
  invoiceDate     DateTime
  dueDate         DateTime?
  currency        String     @default("EUR")
  netAmount       Float
  vatAmount       Float
  grossAmount     Float
  documentType    String     @default("INVOICE")
  rawXml          String
  status          String     @default("PENDING")
  confidenceScore Float      @default(0)
  xeroInvoiceId   String?
  externalRef     String?
  failureReason   String?
  receivedAt      DateTime   @default(now())
  processedAt     DateTime?
  postedAt        DateTime?
  client          Client     @relation(fields: [clientId], references: [id])
  supplier        Supplier?  @relation(fields: [supplierId], references: [id])
  lineItems       LineItem[]
  auditLogs       AuditLog[]
  exception       Exception?

  @@map("invoices")
}

model LineItem {
  id          String  @id @default(uuid())
  invoiceId   String
  description String
  quantity    Float
  unitPrice   Float
  vatRate     Float
  lineTotal   Float
  accountCode String?
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("line_items")
}

model Rule {
  id          String   @id @default(uuid())
  firmId      String
  clientId    String?
  supplierId  String?
  keyword     String?
  accountCode String
  vatRate     Float?
  priority    Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  firm        Firm     @relation(fields: [firmId], references: [id], onDelete: Cascade)
  client      Client?  @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("rules")
}

model Exception {
  id         String            @id @default(uuid())
  invoiceId  String            @unique
  reason     String
  resolvedAt DateTime?
  resolution String?
  invoice    Invoice           @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  reviews    ExceptionReview[]

  @@map("exceptions")
}

model ExceptionReview {
  id          String    @id @default(uuid())
  exceptionId String
  userId      String
  action      String
  accountCode String?
  notes       String?
  reviewedAt  DateTime  @default(now())
  exception   Exception @relation(fields: [exceptionId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id])

  @@map("exception_reviews")
}

model AuditLog {
  id         String   @id @default(uuid())
  invoiceId  String
  action     String
  detail     String?
  ruleId     String?
  confidence Float?
  xeroRef    String?
  createdAt  DateTime @default(now())
  invoice    Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("audit_logs")
}

model XeroToken {
  id           String   @id @default(uuid())
  clientId     String   @unique
  tenantId     String
  accessToken  String
  refreshToken String
  expiresAt    DateTime
  updatedAt    DateTime @updatedAt

  @@map("xero_tokens")
}

model ExactOnlineToken {
  id           String   @id @default(uuid())
  clientId     String   @unique
  division     String
  accessToken  String
  refreshToken String
  expiresAt    DateTime
  updatedAt    DateTime @updatedAt

  @@map("exact_online_tokens")
}

generator client {
  provider        = "prisma-client-js"
  output          = "../src/generated/prisma"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
  relationMode = "prisma"
}

// ─── FIRM ────────────────────────────────────────────────────────────────────
// Plan: STARTER (<=100 clients) | GROWTH (101-500) | SCALE (500+)
model Firm {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  plan      String   @default("STARTER")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users   User[]
  clients Client[]
  rules   Rule[]

  @@map("firms")
}

// ─── USER ────────────────────────────────────────────────────────────────────
// Role: ADMIN | ACCOUNTANT
model User {
  id        String   @id @default(uuid())
  firmId    String
  email     String   @unique
  name      String
  role      String   @default("ACCOUNTANT")
  createdAt DateTime @default(now())

  firm             Firm              @relation(fields: [firmId], references: [id], onDelete: Cascade)
  exceptionReviews ExceptionReview[]

  @@map("users")
}

// ─── CLIENT ──────────────────────────────────────────────────────────────────
// An SME client managed by a firm
// accountingSystem: XERO | EXACT_ONLINE | DATEV | NONE
model Client {
  id               String   @id @default(uuid())
  firmId           String
  name             String
  vatNumber        String?
  peppolId         String?  @unique
  accountingSystem String   @default("NONE")
  xeroTenantId     String?  @unique
  xeroConnected    Boolean  @default(false)
  exactDivision    String?
  exactConnected   Boolean  @default(false)
  datevClientNo    String?
  datevConsultNo   String?
  active           Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  firm      Firm       @relation(fields: [firmId], references: [id], onDelete: Cascade)
  invoices  Invoice[]
  rules     Rule[]
  suppliers Supplier[]

  @@map("clients")
}

// ─── SUPPLIER ────────────────────────────────────────────────────────────────
model Supplier {
  id             String  @id @default(uuid())
  clientId       String
  name           String
  vatNumber      String?
  xeroContactId  String?
  defaultAccount String?

  client   Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  invoices Invoice[]

  @@unique([clientId, vatNumber])
  @@map("suppliers")
}

// ─── INVOICE ─────────────────────────────────────────────────────────────────
// Status: PENDING | PROCESSING | AUTO_POSTED | EXCEPTION | APPROVED | REJECTED | FAILED
model Invoice {
  id              String    @id @default(uuid())
  clientId        String
  supplierId      String?
  invoiceNumber   String
  invoiceDate     DateTime
  dueDate         DateTime?
  currency        String    @default("EUR")
  netAmount       Float
  vatAmount       Float
  grossAmount     Float
  rawXml          String
  status          String    @default("PENDING")
  confidenceScore Float     @default(0)
  xeroInvoiceId   String?
  externalRef     String?
  failureReason   String?
  receivedAt      DateTime  @default(now())
  processedAt     DateTime?
  postedAt        DateTime?

  client    Client     @relation(fields: [clientId], references: [id])
  supplier  Supplier?  @relation(fields: [supplierId], references: [id])
  lineItems LineItem[]
  auditLogs AuditLog[]
  exception Exception?

  @@map("invoices")
}

// ─── LINE ITEM ───────────────────────────────────────────────────────────────
model LineItem {
  id          String  @id @default(uuid())
  invoiceId   String
  description String
  quantity    Float
  unitPrice   Float
  vatRate     Float
  lineTotal   Float
  accountCode String?

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("line_items")
}

// ─── RULE ────────────────────────────────────────────────────────────────────
model Rule {
  id          String   @id @default(uuid())
  firmId      String
  clientId    String?
  supplierId  String?
  keyword     String?
  accountCode String
  vatRate     Float?
  priority    Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  firm   Firm    @relation(fields: [firmId], references: [id], onDelete: Cascade)
  client Client? @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("rules")
}

// ─── EXCEPTION ───────────────────────────────────────────────────────────────
// Resolution: APPROVED | REJECTED | EDITED_AND_APPROVED
model Exception {
  id         String    @id @default(uuid())
  invoiceId  String    @unique
  reason     String
  resolvedAt DateTime?
  resolution String?

  invoice Invoice           @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  reviews ExceptionReview[]

  @@map("exceptions")
}

// ─── EXCEPTION REVIEW ────────────────────────────────────────────────────────
// Action: APPROVED | REJECTED | EDITED_AND_APPROVED
model ExceptionReview {
  id          String   @id @default(uuid())
  exceptionId String
  userId      String
  action      String
  accountCode String?
  notes       String?
  reviewedAt  DateTime @default(now())

  exception Exception @relation(fields: [exceptionId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id])

  @@map("exception_reviews")
}

// ─── AUDIT LOG ───────────────────────────────────────────────────────────────
model AuditLog {
  id        String   @id @default(uuid())
  invoiceId String
  action    String
  detail    String?
  ruleId    String?
  confidence Float?
  xeroRef   String?
  createdAt DateTime @default(now())

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("audit_logs")
}

// ─── XERO TOKEN ──────────────────────────────────────────────────────────────
model XeroToken {
  id           String   @id @default(uuid())
  clientId     String   @unique
  tenantId     String
  accessToken  String
  refreshToken String
  expiresAt    DateTime
  updatedAt    DateTime @updatedAt

  @@map("xero_tokens")
}

// ─── EXACT ONLINE TOKEN ─────────────────────────────────────────────────────
model ExactOnlineToken {
  id           String   @id @default(uuid())
  clientId     String   @unique
  division     String
  accessToken  String
  refreshToken String
  expiresAt    DateTime
  updatedAt    DateTime @updatedAt

  @@map("exact_online_tokens")
}
